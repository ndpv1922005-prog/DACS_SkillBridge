@inject SkillBridge.Api.Services.SkillBridgeService SkillBridgeService
<!doctype html>
<html lang="@UiText.Lang(Context)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - SkillBridge</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    @{
        var activeRole = AuthSession.RoleFor(Context);
        var isTeacherArea = activeRole == UserRole.Teacher;
        var isAdminArea = activeRole == UserRole.Admin;
        var activeName = activeRole is null ? null : AuthSession.UserName(Context, activeRole.Value);
        var activeUserId = activeRole is null ? null : AuthSession.UserId(Context, activeRole.Value);
        var layoutNotifications = activeUserId is null
            ? new List<LayoutNotificationViewModel>()
            : SkillBridgeService.NotificationsForUser(activeUserId.Value).ToList();
        var unreadNotifications = activeUserId is null ? 0 : SkillBridgeService.UnreadNotificationCount(activeUserId.Value);
        var currentLang = UiText.Lang(Context);
        var nextLang = currentLang == "en" ? "vi" : "en";
        string BadgeText(int count) => count > 9 ? "9+" : count.ToString();
    }
    <nav class="navbar navbar-expand-lg navbar-dark border-bottom border-secondary-subtle sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">SkillBridge</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (isAdminArea)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Bảng điều khiển Admin</a></li>
                        <li class="nav-item">
                            <a class="nav-link nav-chat-link" asp-controller="Chat" asp-action="Index" asp-route-role="Admin">
                                Hỗ trợ
                            </a>
                        </li>
                    }
                    else if (isTeacherArea)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="TeacherDashboard" asp-action="Index">@UiText.T(Context, "TeacherDashboard")</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="TeacherDashboard" asp-action="Students">@UiText.T(Context, "StudentsAndLessons")</a></li>
                        <li class="nav-item">
                            <a class="nav-link nav-chat-link" asp-controller="Chat" asp-action="Index" asp-route-role="Teacher">
                                @UiText.T(Context, "Chat")
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">@UiText.T(Context, "Dashboard")</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Bookings" asp-action="Index">@UiText.T(Context, "LessonsProgress")</a></li>
                        <li class="nav-item">
                            <a class="nav-link nav-chat-link" asp-controller="Chat" asp-action="Index">
                                @UiText.T(Context, "Chat")
                            </a>
                        </li>
                    }
                </ul>
                <div class="d-flex align-items-center gap-2">
                    @if (activeRole is not null && AuthSession.IsSignedIn(Context, activeRole.Value))
                    {
                        <div class="dropdown notification-wrap">
                            <button class="notification-bell" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "Notifications")">
                                <span>🔔</span>
                                @if (unreadNotifications > 0)
                                {
                                    <span class="notification-badge">@BadgeText(unreadNotifications)</span>
                                }
                            </button>
                            <div class="dropdown-menu dropdown-menu-end notification-dropdown">
                                <div class="notification-dropdown-head">
                                    <strong>@UiText.T(Context, "Notifications")</strong>
                                    <small>@UiText.T(Context, "NotificationsNoChat")</small>
                                </div>
                                @if (layoutNotifications.Any())
                                {
                                    @foreach (var notification in layoutNotifications)
                                    {
                                        <div class="notification-item @(notification.IsRead ? "" : "is-unread")">
                                            <span class="notification-icon">@notification.Icon</span>
                                            <span class="notification-content">
                                                <strong>@notification.Title</strong>
                                                @if (!string.IsNullOrWhiteSpace(notification.Body))
                                                {
                                                    <small>@notification.Body</small>
                                                }
                                                <time>@notification.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</time>
                                            </span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="notification-empty">@UiText.T(Context, "NoNotifications")</div>
                                }
                            </div>
                        </div>
                        <form asp-controller="Settings" asp-action="Language" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="language" value="@nextLang" />
                            <button class="language-toggle-btn" type="submit">@(currentLang == "en" ? "VI" : "EN")</button>
                        </form>
                        <span class="text-secondary small">@activeName</span>
                        <a class="btn btn-outline-light btn-sm" asp-controller="Settings" asp-action="Index" asp-route-role="@activeRole">@UiText.T(Context, "Settings")</a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="role" value="@activeRole" />
                            <button class="btn btn-outline-light btn-sm">@UiText.T(Context, "Logout")</button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Settings" asp-action="Language" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="language" value="@nextLang" />
                            <button class="language-toggle-btn" type="submit">@(currentLang == "en" ? "VI" : "EN")</button>
                        </form>
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Register">@UiText.T(Context, "Register")</a>
                        <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">@UiText.T(Context, "Login")</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
