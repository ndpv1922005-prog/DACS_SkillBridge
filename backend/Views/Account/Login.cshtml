@model LoginViewModel
@{
    ViewData["Title"] = UiText.T(Context, "Login");
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="card">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">@UiText.T(Context, "Login")</h1>
                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="alert alert-danger">@Model.Error</div>
                }
                <form asp-action="Login" method="post" class="vstack gap-3">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="form-label">Email</label>
                        <input class="form-control" asp-for="Email" />
                    </div>
                    <div>
                        <div class="d-flex justify-content-between align-items-center">
                            <label class="form-label">@UiText.T(Context, "Password")</label>
                            <a class="small auth-link" href="/forgot-password">@UiText.T(Context, "ForgotPassword")</a>
                        </div>
                        <div class="input-group password-hold-group">
                            <input class="form-control" asp-for="Password" type="password" data-password-field />
                            <button class="btn btn-outline-light password-hold-button" type="button" data-password-hold aria-label="@UiText.T(Context, "HoldToShow")">@UiText.T(Context, "HoldToShow")</button>
                        </div>
                    </div>
                    <button class="btn btn-primary btn-lg">@UiText.T(Context, "Login")</button>
                </form>
                <hr />
                <div class="d-flex justify-content-between align-items-center gap-2">
                    <span class="text-secondary small">@UiText.T(Context, "NoAccount")</span>
                    <a class="btn btn-outline-light btn-sm" asp-action="Register">@UiText.T(Context, "Register")</a>
                </div>
            </div>
        </div>
    </div>
</div>
