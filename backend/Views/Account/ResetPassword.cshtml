@model ResetPasswordViewModel
@{
    ViewData["Title"] = UiText.T(Context, "ResetTitle");
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="card auth-card">
            <div class="card-body p-4">
                <div class="auth-icon mb-3">&#8635;</div>
                <h1 class="h3 mb-2">@UiText.T(Context, "ResetTitle")</h1>
                <p class="text-secondary mb-4">@UiText.T(Context, "ResetText")</p>

                @if (!string.IsNullOrWhiteSpace(Model.Message))
                {
                    <div class="alert alert-success">@Model.Message</div>
                    <a class="btn btn-primary w-100" asp-action="Login">@UiText.T(Context, "BackLogin")</a>
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(Model.Error))
                    {
                        <div class="alert alert-danger">@Model.Error</div>
                    }
                    <form method="post" class="vstack gap-3">
                        @Html.AntiForgeryToken()
                        <div>
                            <label class="form-label">@UiText.T(Context, "NewPassword")</label>
                            <div class="input-group password-hold-group">
                                <input class="form-control" asp-for="NewPassword" type="password" required data-password-field />
                                <button class="btn btn-outline-light password-hold-button" type="button" data-password-hold aria-label="@UiText.T(Context, "HoldToShow")">@UiText.T(Context, "HoldToShow")</button>
                            </div>
                        </div>
                        <div>
                            <label class="form-label">@UiText.T(Context, "ConfirmPassword")</label>
                            <div class="input-group password-hold-group">
                                <input class="form-control" asp-for="ConfirmPassword" type="password" required data-password-field />
                                <button class="btn btn-outline-light password-hold-button" type="button" data-password-hold aria-label="@UiText.T(Context, "HoldToShow")">@UiText.T(Context, "HoldToShow")</button>
                            </div>
                        </div>
                        <button class="btn btn-primary btn-lg">@UiText.T(Context, "ResetPassword")</button>
                    </form>
                }

                <hr />
                <a class="auth-link" href="/forgot-password">@UiText.T(Context, "AnotherLink")</a>
            </div>
        </div>
    </div>
</div>
