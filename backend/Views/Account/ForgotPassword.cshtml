@model ForgotPasswordViewModel
@{
    ViewData["Title"] = UiText.T(Context, "ForgotTitle");
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="card auth-card">
            <div class="card-body p-4">
                <div class="auth-icon mb-3">?</div>
                <h1 class="h3 mb-2">@UiText.T(Context, "ForgotTitle")</h1>
                <p class="text-secondary mb-4">@UiText.T(Context, "ForgotText")</p>

                @if (Model.Submitted)
                {
                    <div class="alert alert-success">
                        @UiText.T(Context, "ForgotSuccess")
                    </div>
                    <a class="btn btn-primary w-100" href="/reset-password">@UiText.T(Context, "GoReset")</a>
                }
                else
                {
                    <form method="post" class="vstack gap-3">
                        @Html.AntiForgeryToken()
                        <div>
                            <label class="form-label">Email</label>
                            <input class="form-control" asp-for="Email" type="email" placeholder="you@example.com" required />
                        </div>
                        <button class="btn btn-primary btn-lg">@UiText.T(Context, "SendResetLink")</button>
                    </form>
                }

                <hr />
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-secondary small">@UiText.T(Context, "RememberPassword")</span>
                    <a class="btn btn-outline-light btn-sm" asp-action="Login">@UiText.T(Context, "Login")</a>
                </div>
            </div>
        </div>
    </div>
</div>
