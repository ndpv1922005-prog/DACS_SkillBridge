@model WalletCheckoutViewModel
@{
    ViewData["Title"] = "Nạp tiền";
    var methods = new[]
    {
        ("Visa / Mastercard", "💳", "Thẻ thanh toán quốc tế"),
        ("Momo", "📱", "Ví điện tử Momo"),
        ("VNPay", "▦", "Quét QR hoặc nhập mã"),
        ("Apple Pay", "", "Thanh toán bằng Apple Pay")
    };
}

<div class="checkout-shell">
    <div class="checkout-hero card">
        <div class="card-body p-4">
            <a class="auth-link small" asp-controller="Dashboard" asp-action="Index" asp-fragment="payments">← Quay lại thanh toán</a>
            <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mt-3">
                <div>
                    <p class="text-uppercase text-success fw-bold small mb-1">Ví học tập</p>
                    <h1 class="h3 mb-1">Nạp tiền</h1>
                    <p class="text-secondary mb-0">Chọn phương thức và xác nhận giao dịch để cộng tiền vào số dư.</p>
                </div>
                <div class="checkout-balance">
                    <span>Số dư hiện tại</span>
                    <strong>@Model.Balance.ToString("N0")đ</strong>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-danger">@Model.Error</div>
    }

    @if (Model.IsConfirmStep)
    {
        <div class="card">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Xác nhận thanh toán</h2>
                <div class="invoice-detail-grid mb-4">
                    <span>Người thanh toán</span><strong>@Model.UserName</strong>
                    <span>Số tiền</span><strong>@Model.Amount.ToString("N0")đ</strong>
                    <span>Phương thức thanh toán</span><strong>@Model.Method</strong>
                    <span>Trạng thái</span><strong>@Model.Status</strong>
                    <span>Mã giao dịch tạm</span><strong>@Model.TransactionCode</strong>
                </div>
                <form asp-action="ConfirmDeposit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="amount" value="@Model.Amount" />
                    <input type="hidden" name="method" value="@Model.Method" />
                    <button class="btn btn-primary btn-lg">Xác nhận thanh toán</button>
                </form>
            </div>
        </div>
    }
    else
    {
        <form asp-action="DepositPreview" method="post" class="checkout-grid">
            @Html.AntiForgeryToken()
            <section class="card">
                <div class="card-body p-4">
                    <h2 class="h4 mb-3">Số tiền muốn nạp</h2>
                    <input class="form-control checkout-amount" type="number" name="amount" min="10000" step="10000" value="@(Model.Amount > 0 ? Model.Amount : 200000)" required />
                    <div class="checkout-quick-amounts mt-3">
                        <button type="button" data-amount="100000">100.000đ</button>
                        <button type="button" data-amount="200000">200.000đ</button>
                        <button type="button" data-amount="500000">500.000đ</button>
                        <button type="button" data-amount="1000000">1.000.000đ</button>
                    </div>
                </div>
            </section>

            <section class="card">
                <div class="card-body p-4">
                    <h2 class="h4 mb-3">Phương thức thanh toán</h2>
                    <div class="payment-method-grid">
                        @foreach (var method in methods)
                        {
                            <label class="payment-method-card">
                                <input type="radio" name="method" value="@method.Item1" checked="@(Model.Method == method.Item1)" data-wallet-method />
                                <span class="payment-method-icon">@method.Item2</span>
                                <strong>@method.Item1</strong>
                                <small>@method.Item3</small>
                            </label>
                        }
                    </div>
                </div>
            </section>

            <section class="card checkout-detail-card">
                <div class="card-body p-4">
                    <h2 class="h4 mb-3">Thông tin thanh toán</h2>
                    <div data-method-fields="Visa / Mastercard" class="wallet-method-fields row g-3">
                        <div class="col-md-6"><label class="form-label">Số thẻ</label><input class="form-control" name="cardNumber" placeholder="4111 1111 1111 1111" /></div>
                        <div class="col-md-6"><label class="form-label">Tên chủ thẻ</label><input class="form-control" name="cardName" placeholder="@Model.UserName" /></div>
                        <div class="col-md-6"><label class="form-label">Ngày hết hạn MM/YY</label><input class="form-control" name="expiry" placeholder="08/29" /></div>
                        <div class="col-md-6"><label class="form-label">CVV</label><input class="form-control" name="cvv" placeholder="123" /></div>
                    </div>
                    <div data-method-fields="Momo" class="wallet-method-fields row g-3 d-none">
                        <div class="col-md-6"><label class="form-label">Số điện thoại ví</label><input class="form-control" name="momoPhone" placeholder="09xxxxxxxx" /></div>
                        <div class="col-md-6"><label class="form-label">Tên chủ ví</label><input class="form-control" name="momoName" placeholder="@Model.UserName" /></div>
                    </div>
                    <div data-method-fields="VNPay" class="wallet-method-fields row g-3 d-none">
                        <div class="col-md-4"><div class="mock-qr">SB</div></div>
                        <div class="col-md-8">
                            <label class="form-label">Mã giao dịch</label><input class="form-control mb-3" name="vnpayCode" value="VNP-@DateTimeOffset.UtcNow.ToUnixTimeSeconds()" />
                            <label class="form-label">Nội dung thanh toán</label><input class="form-control" name="vnpayContent" value="Nap tien SkillBridge" />
                        </div>
                    </div>
                    <div data-method-fields="Apple Pay" class="wallet-method-fields row g-3 d-none">
                        <div class="col-md-8"><label class="form-label">Apple ID / Email Apple Pay</label><input class="form-control" name="appleEmail" placeholder="name@icloud.com" /></div>
                        <div class="col-md-4 d-flex align-items-end"><button class="btn lesson-action-btn w-100" type="button">Thanh toán bằng Apple Pay</button></div>
                    </div>
                    <div class="d-flex justify-content-end mt-4">
                        <button class="btn btn-primary btn-lg">Tiếp tục</button>
                    </div>
                </div>
            </section>
        </form>
    }
</div>

<script>
document.querySelectorAll('[data-amount]').forEach((button) => {
  button.addEventListener('click', () => {
    const input = document.querySelector('.checkout-amount');
    if (input) input.value = button.dataset.amount;
  });
});

function syncWalletFields() {
  const selected = document.querySelector('[data-wallet-method]:checked')?.value;
  document.querySelectorAll('[data-method-fields]').forEach((panel) => {
    panel.classList.toggle('d-none', panel.dataset.methodFields !== selected);
  });
}

document.querySelectorAll('[data-wallet-method]').forEach((input) => {
  input.addEventListener('change', syncWalletFields);
});
syncWalletFields();
</script>
