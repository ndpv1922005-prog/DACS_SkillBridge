@model TeacherDashboardViewModel
@inject SkillBridge.Api.Services.SkillBridgeService SkillBridgeService
@{
    ViewData["Title"] = UiText.T(Context, "StudentsAndLessons");
    var teacherId = AuthSession.UserId(Context, UserRole.Teacher);
    var teacherComplaints = teacherId is null
        ? new List<Complaint>()
        : SkillBridgeService.ComplaintsForTeacher(teacherId.Value).ToList();
    var bookings = Model.Bookings
        .OrderByDescending(booking => booking.StartTime)
        .ThenBy(booking => booking.BookingId)
        .ToList();
}

<div class="teacher-students-page">
    @if (!string.IsNullOrWhiteSpace(Model.Success))
    {
        <div class="alert alert-success toast-like-message">@Model.Success</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-danger">@Model.Error</div>
    }

    <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">@UiText.T(Context, "StudentsAndLessons")</h1>
            <p class="text-secondary mb-0">@UiText.T(Context, "StudentsPageText")</p>
        </div>
        <a asp-controller="TeacherDashboard" asp-action="Index" asp-fragment="schedule" class="btn lesson-action-btn">@UiText.T(Context, "BackToSchedule")</a>
    </div>

    @if (!bookings.Any())
    {
        <div class="empty-state">@UiText.T(Context, "NoRegisteredStudents")</div>
    }
    else
    {
        <div class="student-summary-grid mb-4">
            <div class="stat-card p-3"><span>@UiText.T(Context, "StudentCount")</span><strong>@bookings.Select(booking => booking.StudentId).Distinct().Count()</strong></div>
            <div class="stat-card p-3"><span>@UiText.T(Context, "RegisteredSessions")</span><strong>@bookings.Count</strong></div>
            <div class="stat-card p-3"><span>@UiText.T(Context, "CompletedSessions")</span><strong>@bookings.Count(booking => booking.Status == BookingStatus.Completed)</strong></div>
        </div>

        <div class="card">
            <div class="card-body p-3 p-lg-4">
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle teacher-students-table">
                        <thead>
                            <tr>
                                <th>@UiText.T(Context, "Student")</th>
                                <th>@UiText.T(Context, "LessonContent")</th>
                                <th>@UiText.T(Context, "LearningMode")</th>
                                <th>@UiText.T(Context, "Time")</th>
                                <th>@UiText.T(Context, "LearningStatus")</th>
                                <th>@UiText.T(Context, "Payment")</th>
                                <th class="text-end">@UiText.T(Context, "Progress") / @UiText.T(Context, "Action")</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var booking in bookings)
                        {
                            var progressPercent = ProgressPercent(booking);
                            var statusLabel = LessonStatus(booking);
                            var paymentLabel = booking.IsUnderReview
                                ? UiText.T(Context, "TeacherDisputeStatus")
                                : UiText.T(Context, PaymentStatus(booking));
                            var complaint = teacherComplaints.FirstOrDefault(item => item.BookingId == booking.BookingId);
                            var complaintModalId = $"teacher-complaint-{booking.BookingId:N}";
                            <tr>
                                <td>
                                    <strong>@booking.StudentName</strong>
                                    <div class="text-secondary small">@booking.StartTime.ToLocalTime().ToString("dddd")</div>
                                </td>
                                <td>@booking.LessonContent</td>
                                <td>
                                    <span class="badge text-bg-info">@UiText.T(Context, booking.TeachingMode.ToString())</span>
                                    @if (booking.TeachingMode is TeachingMode.Offline or TeachingMode.Hybrid)
                                    {
                                        <div class="text-secondary small">@booking.OfflineLocation</div>
                                    }
                                </td>
                                <td>@booking.StartTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm") - @booking.EndTime.ToLocalTime().ToString("HH:mm")</td>
                                <td><span class="badge text-bg-success">@statusLabel</span></td>
                                <td><span class="badge text-bg-info">@paymentLabel</span></td>
                                <td class="text-end">
                                    <div class="lesson-progress-actions">
                                        <div class="lesson-progress-compact">
                                            <div class="progress compact-progress" role="progressbar" aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100">
                                                <div class="progress-bar" style="width: @progressPercent%"></div>
                                            </div>
                                            <span>@progressPercent%</span>
                                        </div>
                                        <div class="lesson-actions justify-content-end">
                                            @if (booking.Status == BookingStatus.Pending)
                                            {
                                                <form asp-action="Confirm" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@booking.BookingId" />
                                                    <input type="hidden" name="returnTo" value="Students" />
                                                    <button class="btn btn-sm lesson-action-btn">@UiText.T(Context, "Confirm")</button>
                                                </form>
                                                <form asp-action="Reject" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@booking.BookingId" />
                                                    <input type="hidden" name="returnTo" value="Students" />
                                                    <button class="btn btn-sm lesson-action-btn">@UiText.T(Context, "Reject")</button>
                                                </form>
                                            }
                                            @if ((booking.TeachingMode is TeachingMode.Online or TeachingMode.Hybrid) && booking.Status is (BookingStatus.Paid or BookingStatus.InProgress))
                                            {
                                                if (booking.TeacherCompleted)
                                                {
                                                    <button class="btn btn-sm lesson-action-btn" type="button" disabled>@UiText.T(Context, "JoinClass")</button>
                                                }
                                                else
                                                {
                                                    <a asp-controller="Bookings" asp-action="Room" asp-route-id="@booking.BookingId" asp-route-role="Teacher" class="btn btn-sm lesson-action-btn">@UiText.T(Context, "JoinClass")</a>
                                                }
                                            }
                                            @if (booking.Status is BookingStatus.Paid or BookingStatus.InProgress)
                                            {
                                                <form asp-action="CompleteTeaching" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@booking.BookingId" />
                                                    <input type="hidden" name="returnTo" value="Students" />
                                                    <button class="btn btn-sm lesson-action-btn" disabled="@(booking.TeacherCompleted || booking.IsUnderReview)">@UiText.T(Context, "Confirmed")</button>
                                                </form>
                                            }
                                            @if (complaint is not null)
                                            {
                                                <button class="btn btn-sm lesson-action-btn" type="button" data-bs-toggle="modal" data-bs-target="#@complaintModalId">Phản hồi khiếu nại</button>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            @if (complaint is not null)
                            {
                                <tr class="d-none"><td colspan="7">
                                    <div class="modal fade" id="@complaintModalId" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content complaint-modal">
                                                <form asp-action="RespondComplaint" method="post" enctype="multipart/form-data">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@complaint.Id" />
                                                    <div class="modal-header border-secondary-subtle">
                                                        <div>
                                                            <h2 class="modal-title h5">Phản hồi khiếu nại</h2>
                                                            <p class="text-secondary small mb-0">@complaint.Reason</p>
                                                        </div>
                                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body vstack gap-3 text-start">
                                                        @if (!string.IsNullOrWhiteSpace(complaint.StudentEvidenceUrl))
                                                        {
                                                            <a class="auth-link" href="@complaint.StudentEvidenceUrl" target="_blank">Xem bằng chứng học sinh</a>
                                                        }
                                                        <label class="form-label">Nội dung phản hồi</label>
                                                        <textarea class="form-control" name="response" rows="4" maxlength="1200">@complaint.TeacherResponse</textarea>
                                                        <label class="form-label">Bằng chứng giáo viên</label>
                                                        <input class="form-control" type="file" name="evidenceFile" accept="image/*" />
                                                    </div>
                                                    <div class="modal-footer border-secondary-subtle">
                                                        <button type="button" class="btn lesson-action-btn" data-bs-dismiss="modal">Hủy</button>
                                                        <button class="btn lesson-action-btn" type="submit">Gửi phản hồi</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td></tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@functions {
    private string LessonStatus(TeacherBookingRowViewModel booking)
    {
        if (booking.IsUnderReview)
        {
            return UiText.T(Context, "UnderReviewStatus");
        }

        if (booking.Status == BookingStatus.Completed || (booking.StudentCompleted && booking.TeacherCompleted))
        {
            return UiText.T(Context, "Completed");
        }

        if (booking.StudentCompleted || booking.TeacherCompleted)
        {
            return UiText.T(Context, "WaitingOtherSide");
        }

        if (booking.Status is BookingStatus.Paid or BookingStatus.InProgress)
        {
            return UiText.T(Context, "InProgress");
        }

        return UiText.T(Context, booking.Status.ToString());
    }

    private static int ProgressPercent(TeacherBookingRowViewModel booking)
    {
        if (booking.Status == BookingStatus.Completed || (booking.StudentCompleted && booking.TeacherCompleted))
        {
            return 100;
        }

        if (booking.StudentCompleted || booking.TeacherCompleted)
        {
            return 75;
        }

        return booking.Status switch
        {
            BookingStatus.Paid or BookingStatus.InProgress => 50,
            BookingStatus.Confirmed => 30,
            _ => 10
        };
    }

    private static string PaymentStatus(TeacherBookingRowViewModel booking) =>
        booking.Status is BookingStatus.Paid or BookingStatus.InProgress or BookingStatus.Completed
            ? "PaidStatus"
            : "UnpaidStatus";
}
