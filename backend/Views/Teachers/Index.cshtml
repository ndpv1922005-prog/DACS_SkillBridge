@model TeacherListViewModel
@{
    ViewData["Title"] = UiText.T(Context, "Teachers");
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">@UiText.T(Context, "Teachers")</h1>
        <p class="text-secondary mb-0">@UiText.T(Context, "TeacherSearchText")</p>
    </div>
    <form method="get" class="d-flex gap-2">
        <input class="form-control" name="query" value="@Model.Query" placeholder="@UiText.T(Context, "SearchSkill")" />
        <select class="form-select" name="mode">
            <option value="">@UiText.T(Context, "All")</option>
            @foreach (var mode in Enum.GetValues<TeachingMode>())
            {
                <option value="@mode" selected="@(Model.Mode == mode)">@UiText.T(Context, mode.ToString())</option>
            }
        </select>
        <button class="btn btn-primary">@UiText.T(Context, "Search")</button>
    </form>
</div>

<div class="row g-3">
    @foreach (var teacher in Model.Teachers)
    {
        <div class="col-md-6 col-xl-3">
            <partial name="_TeacherCard" model="teacher" />
        </div>
    }
</div>
